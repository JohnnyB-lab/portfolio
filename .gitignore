# Gitignore for Portfolio Project

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build outputs
dist/
build/
*.min.js
*.min.css

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (if using package.json)
node_modules/
package-lock.json
yarn.lock

# Temporary files
*.tmp
*.temp
.cache/

# Archive files
*.zip
*.rar
*.7z
*.tar.gz